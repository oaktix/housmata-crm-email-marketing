# Logs
/logs
*.log
# Do not ignore the API source directory that happens to be named "logs"
!src/app/api/logs
!src/app/api/logs/**
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-modules
node_modules/
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Redirect styleguide tool output
.styleguide/

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# Local env files (DANGER: DO NOT REMOVE)
.env*.local
.env

# Next.js build output
.next/
out/

# Vercel
.vercel

# Editor files
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
